# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Backend server URL — used for:
#   - Socket.io connection (presence, notifications)
#   - Yjs WebSocket connection (ws://localhost:5000/yjs)
# Both run on the SAME server, different paths
VITE_SOCKET_URL=http://localhost:5000

# NOTE: VITE_YJS_WEBSOCKET_URL is no longer needed.
# The backend now serves Yjs on the /yjs path of the main server:
#   ws://localhost:5000/yjs?roomId=doc:<docId>&token=<jwt>
# This is derived automatically from VITE_SOCKET_URL in the editor pages.
