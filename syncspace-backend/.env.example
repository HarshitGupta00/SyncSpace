# =============================================
# SyncSpace Backend — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git — only commit .env.example
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Get this from MongoDB Atlas (cloud) or use local: mongodb://localhost:27017/syncspace
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/syncspace

# JWT
# Use a long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# JWT Invite Token (separate secret + shorter expiry for security)
INVITE_JWT_SECRET=another_random_secret_for_invites
INVITE_JWT_EXPIRES_IN=48h

# Frontend URL (for CORS + email links)
CLIENT_URL=http://localhost:5173

# Email — Resend (recommended: resend.com, free tier = 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx

# OR if using Nodemailer with Gmail SMTP instead:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourapp@gmail.com
# SMTP_PASS=your_gmail_app_password

# OpenAI (for RAG — chat + embeddings)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Pinecone (vector DB for RAG)
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_INDEX_NAME=syncspace-docs

# Google OAuth (optional — only if implementing "Continue with Google")
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
